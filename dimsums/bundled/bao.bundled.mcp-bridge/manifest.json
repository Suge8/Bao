{
  "apiVersion": "bao.dimsum/v1",
  "id": "bao.bundled.mcp-bridge",
  "name": "Bao Bundled MCP Bridge",
  "version": "0.0.0",
  "types": [
    "tool",
    "bridge"
  ],
  "runtime": {
    "kind": "process",
    "process": {
      "command": "cargo",
      "args": [
        "run",
        "-q",
        "-p",
        "bao-dimsum-process",
        "--bin",
        "bao-mcp-bridge",
        "--"
      ],
      "protocol": "bao-jsonrpc/v1"
    }
  },
  "compat": {
    "baoCore": ">=0.0.0",
    "os": [
      "macos",
      "windows",
      "linux"
    ],
    "arch": [
      "arm64",
      "x64"
    ]
  },
  "permissionsRequested": [
    {
      "cap": "net.access",
      "reason": "Connect to MCP servers (http/sse) when configured"
    },
    {
      "cap": "cmd.exec",
      "reason": "Spawn MCP servers over stdio when configured"
    }
  ],
  "distribution": {
    "channel": "bundled",
    "integrity": {
      "sha256": "22971d412688947e391e42aa998719b80ae31c1f03f30b2bb18d239a5cfeda71"
    }
  },
  "tests": {
    "goldenPrompts": "tests/golden_prompts.json"
  }
}
