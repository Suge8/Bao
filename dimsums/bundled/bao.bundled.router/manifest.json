{
  "apiVersion": "bao.dimsum/v1",
  "id": "bao.bundled.router",
  "name": "Bao Bundled Router",
  "version": "0.0.0",
  "types": ["pipeline"],
  "runtime": {
    "kind": "process",
    "process": {
      "command": "cargo",
      "args": [
        "run",
        "-q",
        "-p",
        "bao-dimsum-process",
        "--bin",
        "bao-router-hook",
        "--"
      ],
      "protocol": "bao-jsonrpc/v1"
    }
  },
  "compat": {
    "baoCore": ">=0.0.0",
    "os": ["macos", "windows", "linux"],
    "arch": ["arm64", "x64"]
  },
  "permissionsRequested": [],
  "distribution": {
    "channel": "bundled",
    "integrity": { "sha256": "c8b7f4890289adfc1e0272cd5852dbcf4d77ad9852122fccb0f87133417d3f15" }
  },
  "pipelineHooks": [
    {
      "hook": "router.route",
      "version": "bao.router.output/v1",
      "timeoutMs": 30,
      "inputSchemaRef": "bao.router.input/v1",
      "outputSchemaRef": "bao.router.output/v1"
    }
  ],
  "tests": {
    "goldenPrompts": "tests/golden_prompts.json"
  }
}
