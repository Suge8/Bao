# Docker Compose only. Do not use for local non-Docker runtime.

# Optional: shared token between Bao and WhatsApp bridge.
BRIDGE_TOKEN=

# Docker profile for WhatsApp bridge inter-container URL.
BAO_CHANNELS__WHATSAPP__BRIDGE_URL=ws://bao-whatsapp-bridge:3001

# Example model/provider overrides for Docker runtime.
# BAO_AGENTS__DEFAULTS__MODEL=anthropic/claude-sonnet-4-20250514
# BAO_PROVIDERS__MYKEY__TYPE=openai
# BAO_PROVIDERS__MYKEY__API_KEY=sk-xxx
