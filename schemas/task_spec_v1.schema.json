{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "bao.task.spec/v1",
"type": "object",
"required": ["id", "title", "enabled", "schedule", "action"],
"properties": {
"id": { "type": "string", "minLength": 1 },
"title": { "type": "string", "minLength": 1 },
"enabled": { "type": "boolean" },

"schedule": {
  "type": "object",
  "required": ["kind"],
  "properties": {
    "kind": { "type": "string", "enum": ["once", "interval", "cron"] },
    "runAtTs": { "type": "integer", "minimum": 1 },
    "intervalMs": { "type": "integer", "minimum": 1000 },
    "cron": { "type": "string", "minLength": 1 },
    "timezone": { "type": "string" }
  },
  "allOf": [
    { "if": { "properties": { "kind": { "const": "once" } } }, "then": { "required": ["runAtTs"] } },
    { "if": { "properties": { "kind": { "const": "interval" } } }, "then": { "required": ["intervalMs"] } },
    { "if": { "properties": { "kind": { "const": "cron" } } }, "then": { "required": ["cron"] } }
  ]
},

"action": {
  "type": "object",
  "required": ["kind"],
  "properties": {
    "kind": { "type": "string", "enum": ["tool_call"] },
    "toolCall": {
      "type": "object",
      "required": ["dimsumId", "toolName", "args"],
      "properties": {
        "dimsumId": { "type": "string", "minLength": 1 },
        "toolName": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,127}$" },
        "args": { "type": ["object", "array", "string", "number", "boolean", "null"] }
      }
    }
  }
},

"policy": {
  "type": "object",
  "properties": {
    "maxRetries": { "type": "integer", "minimum": 0, "maximum": 1 },
    "timeoutMs": { "type": "integer", "minimum": 1 },
    "killSwitchGroup": { "type": "string" }
  }
}
}
}
