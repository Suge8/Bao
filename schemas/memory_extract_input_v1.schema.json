{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bao.memory.extract_input/v1",
  "type": "object",
  "required": ["sessionId", "userInput", "assistantOutput"],
  "properties": {
    "sessionId": { "type": "string", "minLength": 1 },
    "userInput": { "type": "string" },
    "assistantOutput": { "type": "string" },
    "toolName": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,127}$" },
    "toolTriggered": { "type": "boolean" },
    "toolOk": { "type": "boolean" },
    "providerUsed": { "type": "string" }
  }
}
