{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bao.provider.jsonrpc.methods/v1",
  "type": "object",
  "required": ["methods"],
  "properties": {
    "methods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["method", "paramsSchemaRef", "resultSchemaRef"],
        "properties": {
          "method": { "type": "string", "minLength": 1 },
          "paramsSchemaRef": { "type": "string", "minLength": 1 },
          "resultSchemaRef": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
